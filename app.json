{
  "expo": {
    "name": "VibeHunt",
    "slug": "vibehunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibehunt.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.vibehunt.app",
      "config": {
        "googleMaps": {
          "apiKey": "A_TUA_GOOGLE_MAPS_API_KEY"
        }
      }
    }
  }
}